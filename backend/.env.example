# Server Configuration
NODE_ENV=development
PORT=3001

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/habeshan_market

# JWT
JWT_SECRET=your-secret-key-here-minimum-32-characters-long
JWT_ACCESS_EXPIRY=1d
JWT_REFRESH_EXPIRY=7d
BCRYPT_ROUNDS=10

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Logging
LOG_LEVEL=info

# Payment Gateways
STRIPE_SECRET_KEY=
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
KLARNA_API_KEY=

# Shipping
DHL_API_KEY=

# Email & Notifications
SENDGRID_API_KEY=
WHATSAPP_BUSINESS_TOKEN=
TELEGRAM_BOT_TOKEN=
